<idea-plugin>
    <id>io.github.easyagent</id>
    <name>EasyAgent</name>
    <vendor>EasyAgent</vendor>
    <description>EasyAgent - IntelliJ IDEA Plugin powered by AI</description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup id="EasyAgent.NotificationGroup" displayType="BALLOON"/>
    </extensions>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow id="EasyAgent"
                    anchor="right"
                    factoryClass="io.github.easyagent.ui.toolwindow.EasyAgentToolWindowFactory"
                    icon="/icons/toolWindow.svg"/>
    </extensions>

    <extensions defaultExtensionNs="com.intellij">
        <projectService serviceImplementation="io.github.easyagent.settings.EasyAgentState"/>
    </extensions>

    <actions>
        <action id="EasyAgent.InsertFileReferenceFromEditor"
                class="io.github.easyagent.ui.action.InsertFileReferenceFromEditorAction"
                text="Insert as EasyAgent Reference"
                description="Insert the current editor file or selection into EasyAgent">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
        <action id="EasyAgent.InsertFileReferenceFromProjectView"
                class="io.github.easyagent.ui.action.InsertFileReferenceFromProjectViewAction"
                text="Insert into EasyAgent"
                description="Insert selected files into EasyAgent as references">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
